<%- include('partials/header.ejs') %>
<main>
    <div class="container">
        <br>
        <div class="card">
            <div class="card-header">
                <h1>Editar Autor</h1>
            </div>
            <div class="card-body">
                <form action="/sinopse/Editar" method="POST">
                    <input type="hidden" name="id" value="<%= sinopse.id %>">
                    <label>Url:</label>
                    <input type="text" name="url" value="<%= sinopse.imagem %>" placeholder="Insira o nome do autor" class="form-control" required>
                    <label>Titulo:</label>
                    <input type="text" name="titulo" value="<%= sinopse.titulo %>" placeholder="Insira a idade do autor" class="form-control" required>
                    <label>Sinopse:</label>
                    <input type="text" name="sinopse" value="<%= sinopse.sinopse %>" placeholder="Insira a idade do autor" class="form-control" required>
                    <label>Autor:</label>
                    <select name="autorId" class="autor-select">
                            <% autor.forEach(aut =>{ %>
                                <option value="<%= aut.id%>"> <%= aut.nomeAutor %></option>
                            <%})%>   
                        </select>
                    <br>
                    <button type="submit" class="btn btn-success">Cadastrar</button>
                    <button type="reset" class="btn btn-danger">Limpar</button>
                </form>
                <hr>
            </div>
        </div>
    </div>
</main>
</body>
</html>