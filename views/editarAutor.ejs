<%- include('partials/header.ejs') %>
    <main>
        <div class="container">
            <br>
            <div class="card">
                <div class="card-header">
                    <h1>Editar Autor</h1>
                </div>
                <div class="card-body">
                    <form action="/Autor/Alterar" method="POST">
                        <input type="hidden" name="id" value="<%= Alterar.id %>">
                        <label>Nome Autor:</label>
                        <input type="text" name="nome" value="<%= Alterar.nomeAutor %>"
                            placeholder="Insira o nome do autor" class="form-control" required>
                        <label>Idade Autor:</label>
                        <input type="text" name="idade" value="<%= Alterar.idadeAutor %>"
                            placeholder="Insira a idade do autor" class="form-control" required>
                        <br>
                        <button type="submit" class="btn btn-success">Cadastrar</button>
                        <button type="reset" class="btn btn-danger">Limpar</button>
                    </form>
                    <hr>
                </div>
            </div>
        </div>
    </main>
</body>
</html>